# === Required: SSO Authentication ===

# Keycloak OIDC (for AWS credential resolution via AssumeRoleWithWebIdentity)
E2E_KEYCLOAK_ISSUER=https://keycloak-keycloak-prod.apps.sno-1-lhxcf.aws-acm-cluster-virt.devcluster.openshift.com/realms/fleetshift
E2E_KEYCLOAK_CLIENT_ID=fleetshift-cli

# Signing key enrollment (for attestation / --sign deployments)
# E2E_ENROLLMENT_CLIENT_ID=fleetshift-signing

# AWS IAM role (created by setup-aws-oidc-federation.sh)
E2E_ROLE_ARN=arn:aws:iam::428315660117:role/OCP-Provisioner

# Red Hat SSO (for pull secret acquisition)
E2E_RH_SSO_ISSUER=https://sso.redhat.com/auth/realms/redhat-external
E2E_RH_SSO_CLIENT_ID=ocm-cli

# === Cluster Configuration (all have defaults) ===

# E2E_BASE_DOMAIN=aws-acm-cluster-virt.devcluster.openshift.com
# E2E_REGION=us-west-2
# E2E_RELEASE_IMAGE=quay.io/openshift-release-dev/ocp-release:4.20.18-x86_64

# === Optional: Cluster Sizing ===

# E2E_WORKER_COUNT=3
# E2E_WORKER_INSTANCE_TYPE=m6i.xlarge
