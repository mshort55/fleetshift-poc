# === Required: SSO Authentication ===

# Keycloak OIDC (for AWS credential resolution via AssumeRoleWithWebIdentity)
E2E_KEYCLOAK_ISSUER=https://<keycloak-route>/realms/fleetshift
E2E_KEYCLOAK_CLIENT_ID=fleetshift-cli

# AWS IAM role (created by e2e/setup/aws-oidc-federation/setup-aws-oidc-federation.sh)
E2E_ROLE_ARN=arn:aws:iam::<account-id>:role/OCP-Provisioner

# Red Hat SSO (for pull secret acquisition)
E2E_RH_SSO_ISSUER=https://sso.redhat.com/auth/realms/redhat-external

# OCP console OIDC client secret (from Keycloak ocp-console client)
# Retrieve: oc get secret ocp-console-client-secret -n keycloak-prod -o jsonpath='{.data.clientSecret}' | base64 -d
E2E_CONSOLE_CLIENT_SECRET=

# === Cluster Configuration (all have defaults) ===

# E2E_BASE_DOMAIN=aws-acm-cluster-virt.devcluster.openshift.com
# E2E_REGION=us-west-2
E2E_RELEASE_IMAGE=quay.io/openshift-release-dev/ocp-release:4.21.0-multi

# === Optional: Cluster Sizing ===

# E2E_WORKER_COUNT=3
# E2E_WORKER_INSTANCE_TYPE=m6i.xlarge
