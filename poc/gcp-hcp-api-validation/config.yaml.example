# HCP Lifecycle Script Configuration
# Copy to config.yaml and fill in your values.

# OIDC Identity Provider
oidc_authorize_url: "https://your-idp.example.com/realms/your-realm/protocol/openid-connect/auth"
oidc_token_url: "https://your-idp.example.com/realms/your-realm/protocol/openid-connect/token"
oidc_client_id: "your-client-id"

# GCP Workforce Identity Federation
gcp_project: "your-broker-project"
workforce_pool: "your-workforce-pool"
workforce_provider: "your-provider"

# Broker Service Account
broker_sa_email: "broker-sa@your-project.iam.gserviceaccount.com"

# CLS Backend API Gateway
gateway_url: "https://your-gateway.uc.gateway.dev"
gateway_audience: "your-oauth-client-id.apps.googleusercontent.com"

# Cluster Defaults
project: "your-target-gcp-project"
region: "us-central1"
endpoint_access: "PublicAndPrivate"
replicas: 2
