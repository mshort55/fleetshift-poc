# GCP HCP API Auth Validation POC — Configuration
# Copy this file to config.env and fill in your values.
# config.env is gitignored — never commit secrets.

# --- GCP ---
GCP_PROJECT="your-gcp-project"
GCP_ORG_ID="your-org-id"               # Required: workforce pools are org-level
WORKFORCE_POOL="ome-poc-pool"
WORKFORCE_PROVIDER="keycloak-poc"

# --- Keycloak ---
KEYCLOAK_URL="https://your-keycloak.example.com"
KEYCLOAK_REALM="your-realm"
KEYCLOAK_CLIENT_ID="ome-poc-client"
KEYCLOAK_CLIENT_SECRET=""               # Only if confidential client

# --- GCP HCP API Gateway ---
GATEWAY_URL="https://cls-backend-gateway-XXXX.uc.gateway.dev"
GATEWAY_AUDIENCE="32555940559.apps.googleusercontent.com"

# --- Broker Service Account ---
BROKER_SA_EMAIL="your-broker-sa@your-project.iam.gserviceaccount.com"

# --- Target Cluster Infrastructure ---
INFRA_ID="your-infra-id"                    # ≤15 chars, starts with lowercase letter
TARGET_GCP_PROJECT="your-target-project"     # GCP project for hosted cluster infra
REGION="us-central1"                         # GCP region
BILLING_ACCOUNT="your-billing-account-id"    # Billing account for target project
