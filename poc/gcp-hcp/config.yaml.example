# HCP Lifecycle Script Configuration
# Copy to config.yaml and fill in your values.

# OIDC identity provider used for browser login.
# The issuer must publish .well-known/openid-configuration and the id_token must include email.
oidc_issuer_url: "https://your-idp.example.com/realms/your-realm"
oidc_client_id: "your-client-id"

# GCP project for all resources: workforce quota, broker SA, and HyperShift infra.
gcp_project: "your-gcp-project"

# Workforce Identity Federation (org-level pool/provider used for STS exchange).
workforce_pool: "your-workforce-pool"
workforce_provider: "your-provider"

# Broker service account that mints Google-signed ID tokens for the gateway.
broker_sa_email: "broker-sa@your-gcp-project.iam.gserviceaccount.com"

# CLS gateway.
gateway_url: "https://your-gateway.example.com"
# Audience for the final Google-signed broker ID token accepted by the gateway.
gateway_audience: "your-gateway-audience"

# HyperShift cluster settings.
region: "us-central1"
endpoint_access: "PublicAndPrivate"
replicas: 2
