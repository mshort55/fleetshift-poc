{
  "realm": "fleetshift",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "components": {
    "org.keycloak.userprofile.UserProfileProvider": [
      {
        "providerId": "declarative-user-profile",
        "config": {
          "kc.user.profile.config": [
            "{\"attributes\":[{\"name\":\"username\",\"displayName\":\"${username}\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"validations\":{\"length\":{\"min\":3,\"max\":255},\"username-prohibited-characters\":{},\"up-username-not-idn-homograph\":{}}},{\"name\":\"email\",\"displayName\":\"${email}\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"validations\":{\"email\":{},\"length\":{\"max\":255}}},{\"name\":\"firstName\",\"displayName\":\"${firstName}\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"validations\":{\"length\":{\"max\":255},\"person-name-prohibited-characters\":{}}},{\"name\":\"lastName\",\"displayName\":\"${lastName}\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"validations\":{\"length\":{\"max\":255},\"person-name-prohibited-characters\":{}}},{\"name\":\"signing_public_key\",\"displayName\":\"Signing Public Key\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]}},{\"name\":\"github_username\",\"displayName\":\"GitHub Username\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]}}],\"unmanagedAttributePolicy\":\"ENABLED\"}"
          ]
        }
      }
    ]
  },
  "roles": {
    "realm": [
      {
        "name": "ops",
        "description": "Operations persona — manages clusters and infrastructure"
      },
      {
        "name": "dev",
        "description": "Developer persona — manages applications"
      }
    ]
  },
  "clients": [
    {
      "clientId": "fleetshift-ui",
      "name": "FleetShift UI",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost:8085/*"
      ],
      "webOrigins": [
        "http://localhost:8085"
      ],
      "protocol": "openid-connect",
      "defaultClientScopes": [
        "basic",
        "web-origins",
        "profile",
        "roles",
        "email"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "fleetshift-ui",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "github-username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "github_username",
            "claim.name": "github_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "signing-public-key",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "signing_public_key",
            "claim.name": "signing_public_key",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "fleetshift-cli",
      "name": "FleetShift CLI",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost:8888/callback",
        "http://127.0.0.1/callback",
        "http://localhost:8080/*"
      ],
      "webOrigins": [
        "http://localhost:8888",
        "http://127.0.0.1",
        "http://localhost:8080"
      ],
      "protocol": "openid-connect",
      "defaultClientScopes": [
        "basic",
        "profile",
        "roles",
        "email"
      ],
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "true",
        "oidc.ciba.grant.enabled": "false",
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "fleetshift-cli",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "fleetshift-signing",
      "name": "FleetShift Signing (Key Enrollment)",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://127.0.0.1/callback"
      ],
      "webOrigins": ["+"],
      "protocol": "openid-connect",
      "defaultClientScopes": [
        "basic",
        "profile",
        "roles",
        "email"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "fleetshift-signing-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "fleetshift-signing",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        },
        {
          "name": "github-username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "github_username",
            "claim.name": "github_username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "jsonType.label": "String"
          }
        },
        {
          "name": "signing-public-key",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "signing_public_key",
            "claim.name": "signing_public_key",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "ocp-console",
      "name": "OCP Web Console",
      "enabled": true,
      "publicClient": false,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "secret": "GENERATED_AT_DEPLOY_TIME",
      "redirectUris": [],
      "webOrigins": ["+"],
      "protocol": "openid-connect",
      "defaultClientScopes": [
        "basic",
        "profile",
        "roles",
        "email"
      ],
      "protocolMappers": [
        {
          "name": "ocp-console-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "ocp-console",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "ops",
      "email": "ops@fleetshift.local",
      "firstName": "Ops",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "GENERATED_AT_DEPLOY_TIME",
          "temporary": false
        }
      ],
      "realmRoles": ["ops"],
      "clientRoles": {
        "account": ["manage-account", "view-profile"]
      },
      "attributes": {
        "github_username": ["ops-github"]
      }
    },
    {
      "username": "dev",
      "email": "dev@fleetshift.local",
      "firstName": "Dev",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "GENERATED_AT_DEPLOY_TIME",
          "temporary": false
        }
      ],
      "realmRoles": ["dev"],
      "clientRoles": {
        "account": ["manage-account", "view-profile"]
      },
      "attributes": {
        "github_username": ["dev-github"]
      }
    }
  ]
}
